# Neon (same database as the engine/CLI)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# OAuth — create the apps (see web/README.md), then fill these in (.env, gitignored)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where providers redirect back after login (must match the apps' callback URLs)
OAUTH2_CALLBACK_URI=http://localhost:3000/oauth2/callback
