# Neon (same database as the engine/CLI)
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"

# OAuth — create the apps (see web/README.md), then fill these in (.env, gitignored)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Where providers redirect back after login (must match the apps' callback URLs)
OAUTH2_CALLBACK_URI=http://localhost:3000/oauth2/callback

# Stripe (billing tiers). Leave blank and the server still runs — billing routes answer 503
# "billing not configured" until these are set. See docs/BILLING.md.
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
# Requires written marketplace approval from the payment provider. Keep false until approved.
STRIPE_WALLET_FUNDING_ENABLED=false
# Required in live mode as a second safety lock. Store the Stripe support case or
# approval reference here only after Stripe approves Renown's exact marketplace model.
STRIPE_MARKETPLACE_APPROVAL_REFERENCE=

# Optional production chain-adapter gateway. Off-chain settlement remains final even
# while an anchor retries; the gateway returns {"chainRef":"..."} idempotently.
RENOWN_ONCHAIN_TRANSFER_URL=
RENOWN_ONCHAIN_TRANSFER_SECRET=
# Price IDs for the paid tiers (create the products/prices in the Stripe dashboard).
STRIPE_PRICE_SUPPORTER=
STRIPE_PRICE_PRO=

# Abuse guard: optional comma-separated IP/CIDR denylist applied to the OAuth login flow.
ABUSE_IP_DENYLIST=
