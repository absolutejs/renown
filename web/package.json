{
  "name": "@absolutejs/renown-web",
  "version": "0.0.0",
  "private": true,
  "description": "Renown web — AbsoluteJS (Elysia + React) app: profiles, leaderboards, achievement gallery, OAuth (GitHub + Google) via @absolutejs/auth.",
  "type": "module",
  "scripts": {
    "dev": "absolute dev",
    "build": "absolute build",
    "start": "absolute start",
    "config": "absolute config",
    "typecheck": "absolute typecheck",
    "db:push": "drizzle-kit push",
    "provision:m2m": "bun run scripts/provision-m2m-client.ts",
    "stripe:local": "stripe listen --forward-to http://localhost:7777/webhooks/stripe --events customer.subscription.created,customer.subscription.updated,customer.subscription.deleted,checkout.session.completed"
  },
  "dependencies": {
    "@absolutejs/absolute": "0.19.0-beta.1047",
    "@absolutejs/auth": "0.27.0-beta.7",
    "@absolutejs/linked-providers": "0.0.2",
    "@absolutejs/sync": "0.6.0",
    "@elysiajs/cron": "^1.4.2",
    "@neondatabase/serverless": "^1.0.0",
    "@react-spring/three": "^10.1.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "citra": "0.25.11",
    "drizzle-orm": "^0.41.0",
    "elysia": "1.4.26",
    "elysia-rate-limit": "^4.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-router": "^7.1.0",
    "stripe": "^20.2.0",
    "three": "^0.184.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "drizzle-kit": "^0.30.6",
    "typescript": "5.9.3"
  }
}
